{
  "name": "continuity-hooks",
  "version": "1.0.0",
  "description": "TypeScript hooks for Claude Code continuity plugin",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "bin", "src"],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage",
    "hook": "tsx bin/run-hook.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@tsconfig/node22": "^22.0.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^2.1.0"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  },
  "keywords": ["claude", "hooks", "continuity", "plugin"],
  "license": "UNLICENSED",
  "private": true
}
